<mvc:View
  controllerName="iflow.map.prototype.controller.Mermaid"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true"
  height="100%"
>
  <Page title="Mermaid Diagram">
    <content>
      <VBox class="sapUiSmallMargin">
        <Toolbar>
          <Title text="Impact Analysis" level="H4" />
          <ToolbarSpacer />
          <Select id="mmIflowSelect" width="22rem" change=".onSelectedIflowChange" />
          <Button text="Highlight Connected" type="Emphasized" press=".onHighlightImpactPress" />
          <Button text="Reset" press=".onResetHighlightPress" />
        </Toolbar>
        <HBox class="sapUiTinyMarginTop sapUiTinyMarginBottom" renderType="Bare">
          <ObjectStatus text="ProcessDirect" state="Information" class="sapUiTinyMarginEnd" />
          <ObjectStatus text="JMS" state="Success" class="sapUiTinyMarginEnd" />
          <ObjectStatus text="DataStore" state="Warning" class="sapUiTinyMarginEnd" />
        </HBox>
        <ScrollContainer id="mermaidScroll" height="48rem" vertical="true" horizontal="true">
          <core:HTML content="&lt;div id='mermaidContainer' class='mermaidContainer'&gt;&lt;/div&gt;" />
        </ScrollContainer>
      </VBox>
    </content>
  </Page>
</mvc:View>
