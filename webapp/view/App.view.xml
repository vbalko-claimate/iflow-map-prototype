<mvc:View
  controllerName="iflow.map.prototype.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:tnt="sap.tnt"
  xmlns:core="sap.ui.core"
  displayBlock="true"
  height="100%"
>
  <tnt:ToolPage id="toolPage">
    <tnt:header>
      <tnt:ToolHeader>
        <Title text="iFlow Map" level="H4" class="sapUiSmallMarginBegin">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
        </Title>
        <ToolbarSpacer />
        <Label text="Package:" labelFor="packageFilter">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
        </Label>
        <Select id="packageFilter" width="14rem" change=".onPackageFilterChange">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
          <core:Item key="ALL" text="All Packages" />
        </Select>
        <ToolbarSeparator />
        <Label text="Status:" labelFor="deploymentFilter">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
        </Label>
        <Select id="deploymentFilter" width="10rem" change=".onDeploymentFilterChange">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
          <core:Item key="ALL" text="All Statuses" />
          <core:Item key="STARTED" text="Deployed" />
          <core:Item key="NOT_DEPLOYED" text="Not Deployed" />
          <core:Item key="ERROR" text="Error" />
        </Select>
        <ToolbarSeparator />
        <Label text="Focus:" labelFor="entityFilter">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
        </Label>
        <Select id="entityFilter" width="15rem" change=".onEntityFilterChange">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
          <core:Item key="ALL" text="No Focus" />
        </Select>
        <ToolbarSeparator />
        <SegmentedButton id="modeToggle" selectionChange=".onModeChange">
          <layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
          <items>
            <SegmentedButtonItem key="connection" text="Connection Map" />
            <SegmentedButtonItem key="context" text="Context Map" />
          </items>
        </SegmentedButton>
      </tnt:ToolHeader>
    </tnt:header>
    <tnt:sideContent>
      <tnt:SideNavigation id="sideNav" itemSelect=".onNavItemSelect">
        <tnt:NavigationList>
          <tnt:NavigationListItem text="UI5 NetworkGraph" key="NetworkGraph" icon="sap-icon://workflow-tasks" />
          <tnt:NavigationListItem text="D3 Force"         key="D3Force"       icon="sap-icon://scatter-chart" />
          <tnt:NavigationListItem text="Cytoscape"        key="Cytoscape"     icon="sap-icon://org-chart" />
          <tnt:NavigationListItem text="Mermaid"          key="Mermaid"       icon="sap-icon://flowchart" />
        </tnt:NavigationList>
      </tnt:SideNavigation>
    </tnt:sideContent>
    <tnt:mainContents>
      <NavContainer id="navContainer" height="100%" />
    </tnt:mainContents>
  </tnt:ToolPage>
</mvc:View>
