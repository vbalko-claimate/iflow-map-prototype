<mvc:View
  controllerName="iflow.map.prototype.controller.Cytoscape"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true"
  height="100%"
>
  <Page title="Cytoscape.js Network">
    <content>
      <VBox class="sapUiSmallMargin">
        <Toolbar>
          <Title text="Impact Analysis" level="H4" />
          <ToolbarSpacer />
          <SearchField id="cySearchField" placeholder="Search iFlows..." search=".onSearch" width="16rem" />
          <Select id="cyIflowSelect" width="22rem" change=".onSelectedIflowChange" />
          <Button text="Impact (downstream)" type="Emphasized" press=".onDownstreamPress" />
          <Button text="Dependencies (upstream)" press=".onUpstreamPress" />
          <Button text="Reset" press=".onResetHighlightPress" />
        </Toolbar>
        <Toolbar class="sapUiTinyMarginTop">
          <Label text="Spacing" class="sapUiTinyMarginEnd" />
          <Slider id="cySpacingSlider" min="2000" max="30000" value="8000" width="10rem" liveChange=".onSpacingChange" />
          <ToolbarSpacer width="1rem" />
          <Label text="Link Length" class="sapUiTinyMarginEnd" />
          <Slider id="cyLinkSlider" min="60" max="400" value="160" width="10rem" liveChange=".onLinkDistanceChange" />
          <ToolbarSpacer width="1rem" />
          <Button text="Re-layout" icon="sap-icon://refresh" press=".onRelayoutPress" />
        </Toolbar>
        <HBox class="sapUiTinyMarginTop sapUiTinyMarginBottom" renderType="Bare">
          <ObjectStatus text="ProcessDirect" state="Information" class="sapUiTinyMarginEnd" />
          <ObjectStatus text="JMS" state="Success" class="sapUiTinyMarginEnd" />
          <ObjectStatus text="DataStore" state="Warning" class="sapUiTinyMarginEnd" />
        </HBox>
        <core:HTML content="&lt;div id='cyContainer' class='cyContainer'&gt;&lt;/div&gt;" />
      </VBox>
    </content>
  </Page>
</mvc:View>
